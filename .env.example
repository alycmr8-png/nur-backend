# Nur Backend — Environment Variables
# Copy this to .env and fill in your values

# OpenAI (for your LangGraph agent + embeddings)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Path to your FAISS index folder
# Local: ./faiss_index_cleaned
# On Railway: upload the folder and set the path
FAISS_INDEX_PATH=./faiss_index_cleaned

# Kalimat API (Quran, Hadith, Azkar search)
KALIMAT_API_KEY=c16429ab-eec1-4d6e-ad6f-249f1618346c

# Server
PORT=8000
